{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/product/:path*", "destination": "/#shop", "permanent": true },
    { "source": "/shop", "destination": "/#shop", "permanent": true },
    { "source": "/works", "destination": "/#portfolio", "permanent": true },
    { "source": "/about-me", "destination": "/#about", "permanent": true },
    { "source": "/services", "destination": "/#tours", "permanent": true },
    { "source": "/stories", "destination": "/#ted", "permanent": true },
    { "source": "/contacts", "destination": "/#contact", "permanent": true }
  ],
  "headers": [
    { "source": "/assets/(.*)", "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }] },
    { "source": "/gallery/(.*)", "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }] }
  ]
}
